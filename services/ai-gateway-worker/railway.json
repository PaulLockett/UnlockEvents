{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "watchPatterns": [
    "/services/ai-gateway-worker/**",
    "/packages/ai-gateway/**",
    "/packages/temporal-worker-utils/**"
  ]
}
