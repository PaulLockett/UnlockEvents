{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @unlock-events/ingestion-manager-worker... build",
    "watchPatterns": [
      "/services/ingestion-manager-worker/**",
      "/packages/ingestion-manager/**",
      "/packages/temporal-worker-utils/**",
      "/packages/temporal-interfaces/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @unlock-events/ingestion-manager-worker start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
