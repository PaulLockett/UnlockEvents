{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @unlock-events/experiment-access-worker build",
    "watchPatterns": [
      "/services/experiment-access-worker/**",
      "/packages/experiment-access/**",
      "/packages/temporal-worker-utils/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @unlock-events/experiment-access-worker start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
