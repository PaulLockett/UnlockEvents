{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @unlock-events/extraction-engine-worker build",
    "watchPatterns": [
      "/services/extraction-engine-worker/**",
      "/packages/extraction-engine/**",
      "/packages/temporal-worker-utils/**",
      "/packages/temporal-interfaces/**"
    ]
  },
  "deploy": {
    "startCommand": "pnpm --filter @unlock-events/extraction-engine-worker start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
